# Web (Next.js) env (.env.local for local dev)
STUDIO_API_URL=http://127.0.0.1:8004
SERVICE_TOKEN=dev-service-token

# Auth.js
AUTH_SECRET=                 # openssl rand -base64 32
# Google OAuth (production login):
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Local dev login without Google (any email): set true
AUTH_DEV_LOGIN=true
