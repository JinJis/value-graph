# ============================================================================
# Shared platform env — ONE file for the whole stack (data plane + control plane).
# Both services read this (../.env) first, then any service-local .env override.
# docker compose injects it into every service via `env_file: .env`.
# Copy to .env and fill in your free keys.
# ============================================================================

# --- data plane (datasets) -------------------------------------------------
# Behind the gateway the data plane trusts the caller; the control plane is the auth.
AUTH_DISABLED=true
SEC_EDGAR_USER_AGENT=ValueGraph Datasets contact@example.com
PRICES_PROVIDER_US=yahoo
PRICES_PROVIDER_KR=yahoo
CACHE_TTL_SECONDS=900
HTTP_TIMEOUT_SECONDS=30
# free keys (see datasets/README.md)
OPENDART_API_KEY=
ECOS_API_KEY=
FRED_API_KEY=
# --- ingestion store (screener / historical / 13F need this populated) -----
# The store is EMPTY until backfilled. Two ways to fill it:
#   1) Admin console (:8005) → "Ingestion store → Backfill now" (recommended), or
#      POST /admin/backfill {"market":"US","tickers":["AAPL","MSFT"]} — see /admin/jobs.
#   2) The periodic scheduler below (off by default; set a universe + enable).
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=3600
# e.g. "US:AAPL,MSFT,NVDA;KR:005930,000660" — companies to refresh each cycle.
SCHEDULER_UNIVERSE=
# false = latest few periods (fast); true = full historical backfill (heavy).
SCHEDULER_DEEP=false
# When true, each scheduler tick also pulls fresh news for the universe into RAG
# (PH-2b) so rag__search has recent context. Manual trigger: POST /admin/news/ingest
# {"market":"US","tickers":["AAPL"]} (blank tickers = broad market news).
SCHEDULER_NEWS=false
# The RAG service the news pipeline indexes into, + headlines fetched per ticker.
RAG_URL=http://rag:8002
NEWS_INGEST_LIMIT=8

# --- control plane ---------------------------------------------------------
ADMIN_TOKEN=dev-admin-token
RATE_LIMIT_PER_MINUTE=120

# --- studio-api + web (product layer) --------------------------------------
# Trust token between the web BFF and studio-api.
SERVICE_TOKEN=dev-service-token
# Agent planner: stub (deterministic, no key) | gemini (real LLM, needs GOOGLE_API_KEY)
AGENT_LLM_BACKEND=stub
# Gemini model id used when AGENT_LLM_BACKEND=gemini (any valid Gemini model).
AGENT_MODEL=gemini-flash-latest
# Light/cheap model that assesses query complexity → the agent's step budget (PH-15).
AGENT_BUDGET_MODEL=gemini-flash-lite-latest
# Required for the gemini backend (also used by RAG's gcp embedder). Get one at
# https://aistudio.google.com/apikey  — GOOGLE_API_KEY or GEMINI_API_KEY both work.
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Then run the live LLM end-to-end test:  bash scripts/e2e_live.sh
#
# Web (Next.js / Auth.js). NOTE: docker compose env_file values are literal —
# keep comments on their OWN lines (an inline "# ..." can be parsed into the value,
# which would make AUTH_DEV_LOGIN != "true" and break login).
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me
# Log in with any email locally (no Google needed). Unset this for production.
AUTH_DEV_LOGIN=true
# For real Google OAuth instead, set these (and remove AUTH_DEV_LOGIN):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# DATASETS_URL is set by docker compose to http://datasets:8000; locally defaults
# to http://127.0.0.1:8000.

# --- RAG service (pluggable backends; flip the tier here) ------------------
# embedding: hash (dev) | oss-cpu (fastembed) | oss-gpu (sentence-transformers) | tei | gcp
RAG_EMBEDDING_BACKEND=hash
RAG_EMBEDDING_MODEL=BAAI/bge-m3
# RAG_EMBEDDING_ENDPOINT=          # for tei (GPU served)
# reranker: none | oss-cpu | oss-gpu | tei | gcp
RAG_RERANKER_BACKEND=none
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# vector store: memory (dev) | pgvector
RAG_VECTOR_STORE=memory
# GCP (for RAG_EMBEDDING_BACKEND=gcp and/or RAG_RERANKER_BACKEND=gcp)
# RAG_GCP_PROJECT=
# RAG_GCP_LOCATION=us-central1

# --- infra (optional; default SQLite) --------------------------------------
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...

# --- admin panel (:8005) ---
ADMINUI_USERNAME=admin
ADMINUI_PASSWORD=admin
ADMINUI_SECRET=dev-adminui-secret-change-me
