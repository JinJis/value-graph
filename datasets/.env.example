# --- this service's own auth -------------------------------------------
# Set true for local dev to skip X-API-KEY checks entirely.
AUTH_DISABLED=true
# Comma-separated client keys accepted via the X-API-KEY header (when auth on).
DATASETS_API_KEYS=

# --- US upstreams ------------------------------------------------------
# SEC requires a descriptive User-Agent: "Name email@example.com"
SEC_EDGAR_USER_AGENT=ValueGraph Datasets contact@example.com
FRED_API_KEY=
# optional paid price adapters
POLYGON_API_KEY=
TIINGO_API_KEY=
FMP_API_KEY=

# --- KR upstreams ------------------------------------------------------
OPENDART_API_KEY=
ECOS_API_KEY=
# optional: official KRX OPEN API (otherwise pykrx is used, no key)
KRX_API_KEY=
# optional: Korea Investment & Securities (real-time KR)
KIS_APP_KEY=
KIS_APP_SECRET=

# --- provider selection (override free defaults) -----------------------
PRICES_PROVIDER_US=stooq
PRICES_PROVIDER_KR=pykrx

# --- infra -------------------------------------------------------------
# Ingestion store. SQLite by default; use postgresql://user:pass@host/db in prod.
DATABASE_URL=sqlite:///./datasets.db
REDIS_URL=
CACHE_TTL_SECONDS=900
HTTP_TIMEOUT_SECONDS=30

# --- periodic ingestion scheduler --------------------------------------
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=3600
# Universe to refresh, e.g. "US:AAPL,MSFT,NVDA;KR:005930,000660"
SCHEDULER_UNIVERSE=
