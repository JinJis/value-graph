{
  "name": "@valuegraph/graph-schema",
  "version": "0.0.0",
  "private": true,
  "description": "Single source of truth for node/edge/claim type defs (PRD §5). Canonical JSON Schema -> generated TS types + ajv validators.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./validate": {
      "types": "./src/validate.d.ts",
      "default": "./src/validate.mjs"
    },
    "./schema": "./schema/valuegraph.schema.json"
  },
  "scripts": {
    "generate": "json2ts -i schema/valuegraph.schema.json -o src/types.gen.ts --unreachableDefinitions --no-additionalProperties --bannerComment \"\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test test/"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.3"
  }
}
