{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valuegraph.dev/schema/valuegraph.json",
  "title": "ValueGraph knowledge-graph schema",
  "description": "Canonical, language-neutral single source of truth for ValueGraph nodes, edges, and claims (PRD v5 §5). Consumed by the TS apps (generated types + ajv validation) and the Python services (TypedDicts + jsonschema validation). Schema-reserved edges REVENUE_FLOW / INVESTS_IN / COMPETES_WITH are intentionally NOT defined in v1.",
  "$defs": {
    "ConfidenceTier": {
      "title": "ConfidenceTier",
      "description": "verified (>=2 independent sources, or exact math from a primary filing) | derived (single disclosure + math) | estimated (algorithmic only).",
      "type": "string",
      "enum": ["verified", "derived", "estimated"]
    },
    "Freshness": {
      "title": "Freshness",
      "description": "fresh (<~30d) | aging | stale (past next-expected-filing) | gap (no data).",
      "type": "string",
      "enum": ["fresh", "aging", "stale", "gap"]
    },
    "CostBucket": {
      "title": "CostBucket",
      "description": "Cost-bucket typing used to convert between supplier and customer ledgers.",
      "type": "string",
      "enum": ["COGS", "CAPEX", "R&D", "SG&A"]
    },
    "SourceType": {
      "title": "SourceType",
      "type": "string",
      "enum": ["filing", "IR", "report", "news", "interview"]
    },
    "VerificationStatus": {
      "title": "VerificationStatus",
      "type": "string",
      "enum": ["unverified", "verified", "disputed"]
    },
    "ConfidenceInterval": {
      "title": "ConfidenceInterval",
      "description": "Every quantified figure ships an interval, never a bare point (PRD §6.2).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "low": { "type": "number" },
        "high": { "type": "number" }
      },
      "required": ["low", "high"]
    },
    "DataQuality": {
      "title": "DataQuality",
      "description": "Theme-level mix of confidence tiers, as percentages.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verified": { "type": "number", "minimum": 0, "maximum": 100 },
        "derived": { "type": "number", "minimum": 0, "maximum": 100 },
        "estimated": { "type": "number", "minimum": 0, "maximum": 100 },
        "gap": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "required": ["verified", "derived", "estimated", "gap"]
    },

    "Theme": {
      "title": "Theme",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "depth_max": { "type": "integer", "minimum": 1 },
        "version": { "type": "string" },
        "published_at": { "type": ["string", "null"], "format": "date-time" },
        "data_quality": { "$ref": "#/$defs/DataQuality" }
      },
      "required": ["name"]
    },
    "Company": {
      "title": "Company",
      "description": "A listed company; node size in the Terminal = live market_cap.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ticker": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "exchange": { "type": "string" },
        "market_cap": {
          "description": "Real-time layer (live feed). Not a periodic/disclosure figure.",
          "type": ["number", "null"]
        },
        "price": {
          "description": "Real-time layer (live feed).",
          "type": ["number", "null"]
        },
        "sector": { "type": "string" },
        "tier": { "type": ["integer", "null"], "minimum": 1 },
        "fiscal_calendar": { "type": ["string", "null"] },
        "last_filing_date": { "type": ["string", "null"], "format": "date" },
        "next_filing_estimate": { "type": ["string", "null"], "format": "date" }
      },
      "required": ["ticker", "name"]
    },
    "Division": {
      "title": "Division",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "revenue_share": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "parent_company": { "type": ["string", "null"] }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "category": { "type": ["string", "null"] },
        "cost_bucket_hint": {
          "anyOf": [{ "$ref": "#/$defs/CostBucket" }, { "type": "null" }]
        }
      },
      "required": ["name"]
    },
    "Source": {
      "title": "Source",
      "description": "No number enters the graph without a Source (PRD §4).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/SourceType" },
        "url": { "type": "string", "format": "uri" },
        "publisher": { "type": ["string", "null"] },
        "as_of_date": { "type": "string", "format": "date" },
        "language": { "type": ["string", "null"] },
        "verification_status": { "$ref": "#/$defs/VerificationStatus" }
      },
      "required": ["type", "url", "as_of_date"]
    },
    "Claim": {
      "title": "Claim",
      "description": "One atomic, sourced assertion extracted from a document. No verbatim text_span -> no claim (PRD §6.2 S1).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relation": { "type": "string" },
        "subject": { "type": "string" },
        "object": { "type": "string" },
        "value": { "type": ["number", "null"] },
        "unit": { "type": ["string", "null"] },
        "cost_bucket": {
          "anyOf": [{ "$ref": "#/$defs/CostBucket" }, { "type": "null" }]
        },
        "as_of": { "type": "string", "format": "date" },
        "source_id": { "type": "string" },
        "extracted_by": {
          "description": "Identifier of the extractor (e.g. the Gemini model id / tier).",
          "type": "string"
        },
        "text_span": {
          "description": "Verbatim span the claim was extracted from. Required.",
          "type": "string"
        }
      },
      "required": [
        "relation",
        "subject",
        "object",
        "as_of",
        "source_id",
        "extracted_by",
        "text_span"
      ]
    },

    "HasDivisionEdge": {
      "title": "HasDivisionEdge",
      "description": "Company -> Division. No attributes in v1.",
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "ProducesEdge": {
      "title": "ProducesEdge",
      "description": "Division -> Product.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capacity": { "type": ["number", "null"] },
        "yield": { "type": ["number", "null"] }
      }
    },
    "SuppliesEdge": {
      "title": "SuppliesEdge",
      "description": "Core v1 relationship: a supplier -> customer trade. Per PRD §5.3, every quantitative figure MUST carry as_of_date, next_expected_update, confidence + confidence_interval and a derived freshness. trade_value / shares stay nullable so gaps can be drawn rather than hidden.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supplier": {
          "description": "Supplier company ticker.",
          "type": "string"
        },
        "customer": {
          "description": "Customer company ticker.",
          "type": "string"
        },
        "product_ref": { "type": ["string", "null"] },
        "trade_value": { "type": ["number", "null"] },
        "currency": { "type": ["string", "null"] },
        "supplier_rev_share": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "customer_cost_share": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "cost_bucket": {
          "anyOf": [{ "$ref": "#/$defs/CostBucket" }, { "type": "null" }]
        },
        "confidence": { "$ref": "#/$defs/ConfidenceTier" },
        "confidence_interval": { "$ref": "#/$defs/ConfidenceInterval" },
        "as_of_date": { "type": "string", "format": "date" },
        "next_expected_update": { "type": "string", "format": "date" },
        "freshness": { "$ref": "#/$defs/Freshness" },
        "gap": { "type": "boolean", "default": false }
      },
      "required": [
        "supplier",
        "customer",
        "confidence",
        "confidence_interval",
        "as_of_date",
        "next_expected_update",
        "freshness"
      ]
    },
    "SupportsEdge": {
      "title": "SupportsEdge",
      "description": "Claim -> SUPPLIES. Whether the claim agrees with the reconciled edge value.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weight": { "type": ["number", "null"] },
        "agrees": { "type": "boolean" }
      },
      "required": ["agrees"]
    },
    "SourcedFromEdge": {
      "title": "SourcedFromEdge",
      "description": "Claim -> Source.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extracted_value": { "type": ["number", "string", "null"] }
      }
    }
  }
}
