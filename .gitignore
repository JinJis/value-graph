# Node / pnpm
node_modules/
.pnpm-store/
dist/
build/
.next/
next-env.d.ts
*.tsbuildinfo
# …but a Next.js route segment named "build"/"dist" is SOURCE, not build output — keep it.
!apps/*/app/**/build/
!apps/*/app/**/build/**
!apps/*/app/**/dist/
!apps/*/app/**/dist/**

# Python / uv
.venv/
__pycache__/
*.py[cod]
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Env & secrets (never commit)
.env
.env.*
!.env.example

# Local object storage (uploaded artifacts)
.data/

# OS / editor
.DS_Store
*.log

# Claude Code local agent state (memory, sessions) — not project code
.claude/
