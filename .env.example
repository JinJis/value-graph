# ValueGraph environment — Gemini only. Copy to .env and fill in.
# NEVER commit real secrets; .env is gitignored.

# --- Gemini (single LLM provider; keys server-side only) ---
GOOGLE_API_KEY=

# Model IDs per routing tier — OPTIONAL overrides of the built-in defaults (real,
# current Gemini IDs shown). Leave commented to use the defaults; verify against current
# Google docs before changing. (The PRD's gemini-3.x names are placeholders, not real.)
# MODEL_DEEP=gemini-2.5-pro
# MODEL_MEDIUM=gemini-2.5-flash
# MODEL_LOW=gemini-2.5-flash-lite
# MODEL_RESEARCH=gemini-2.5-pro   # Deep Research Agent wired in M1-DISC-04

# --- Datastores (defaults match infra/docker-compose.yml) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=valuegraph
DATABASE_URL=postgresql://valuegraph:valuegraph@localhost:5432/valuegraph
REDIS_URL=redis://localhost:6379/0

# --- External services (licensed/managed) ---
PINECONE_API_KEY=
MARKET_DATA_API_KEY=
