# ValueGraph environment — Gemini only. Copy to .env and fill in.
# NEVER commit real secrets; .env is gitignored.

# --- Gemini (single LLM provider; keys server-side only) ---
GOOGLE_API_KEY=

# Model IDs per routing tier — OPTIONAL overrides of the built-in defaults (shown).
# Leave commented to use the defaults; verify against current Google docs before changing.
# MODEL_DEEP=gemini-3.1-pro-preview
# MODEL_MEDIUM=gemini-3.5-flash
# MODEL_LOW=gemini-3.1-flash-lite
# RESEARCH is the Gemini Deep Research agent (Interactions API), used for the
# first-pass blueprint generation + constituent discovery — it searches/reads the
# live web so companies come back with REAL citations. Use the "max" agent for
# deeper (slower, pricier) runs: deep-research-max-preview-04-2026.
# MODEL_RESEARCH=deep-research-preview-04-2026

# Per-call timeouts (seconds). Deep Research runs take MINUTES (cap 60 min), so it
# has its own generous timeout separate from ordinary generate_content calls.
# GEMINI_TIMEOUT_SECONDS=120
# DEEP_RESEARCH_TIMEOUT_SECONDS=3600

# --- Datastores (defaults match infra/docker-compose.yml) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=valuegraph
DATABASE_URL=postgresql://valuegraph:valuegraph@localhost:5432/valuegraph
REDIS_URL=redis://localhost:6379/0

# --- External services (licensed/managed) ---
PINECONE_API_KEY=
MARKET_DATA_API_KEY=
