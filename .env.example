# ============================================================================
# Shared platform env — ONE file for the whole stack (data plane + control plane).
# Both services read this (../.env) first, then any service-local .env override.
# docker compose injects it into every service via `env_file: .env`.
# Copy to .env and fill in your free keys.
# ============================================================================

# --- data plane (datasets) -------------------------------------------------
# Behind the gateway the data plane trusts the caller; the control plane is the auth.
AUTH_DISABLED=true
SEC_EDGAR_USER_AGENT=ValueGraph Datasets contact@example.com
PRICES_PROVIDER_US=yahoo
PRICES_PROVIDER_KR=yahoo
# macro: FRED is bot-walled from datacenter IPs; "auto" falls back to keyless,
# cloud-safe DBnomics (BIS policy rates). auto | fred | dbnomics
MACRO_PROVIDER_US=auto
CACHE_TTL_SECONDS=900
LOG_LEVEL=INFO   # app log verbosity for ALL services → docker logs (DEBUG|INFO|WARNING|…). DEBUG adds file:line + funcName, raw model payloads, per-retry traces, request timing.
HTTP_TIMEOUT_SECONDS=30
# free keys (see datasets/README.md)
OPENDART_API_KEY=
ECOS_API_KEY=
FRED_API_KEY=
# BLS public API (labor/price indicators: unemployment, payrolls, CPI, PPI). Keyless works
# (25 queries/day); a free key (bls.gov/developers) raises it to 500/day. We read BLS direct
# because the DBnomics BLS mirror froze at 2025-01.
BLS_API_KEY=
# CE-11: Financial Modeling Prep — analyst consensus estimates + earnings calendar (commercial key)
FMP_API_KEY=
# Alpha Vantage — earnings-call transcripts → RAG + in-app preview (US). A FREE key works
# (alphavantage.co/support/#api-key); free tier is rate-limited (~25 calls/day) so index a few core
# tickers via the admin "transcript_text" pipeline. Unset → the transcript feature stays dark.
ALPHAVANTAGE_API_KEY=
# GCP Document AI — parse 8-K presentation decks (PDF) into RAG (Phase 2). Create a Layout Parser
# processor in the console, grant the SA roles/documentai.apiUser, and point ADC at it
# (GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json — the same SA the reranker uses). Unset
# processor → the deck feature stays dark.
DOCAI_PROJECT=
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=
# CE-12: Korea Investment & Securities (KIS) — KR realtime rankings + investor flows
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS_DOMAIN=https://openapi.koreainvestment.com:9443   # 실전(default); 모의 = https://openapivts.koreainvestment.com:29443
# KIS-PRICES: set to upgrade KR prices/snapshots/charts to KIS realtime (default yahoo). Needs KIS keys above.
# PRICES_PROVIDER_KR=kis
# --- ingestion store + periodic data pipelines (PH-PIPE) -------------------
# The store fills via DATA PIPELINES (financials · prices · corp_actions · news · …).
# Fill it two ways:
#   1) Admin console (:8005) → Pipelines → "백필 — 한 번에 구성" (preset + pipeline checkboxes), or
#      POST /admin/pipelines/run {"preset":"us_xl","pipelines":["financials","prices","news"]}.
#   2) The Procrastinate queue (app/queue.py) — the `worker` compose service runs per-pipeline cron
#      sweeps (news ~hourly · prices ~daily · financials/corp_actions/filing_text ~weekly) and
#      processes the jobs with retries. Monitor/control it in the admin Queue page. To pause all
#      automatic ingestion, stop the worker: `docker compose stop worker`.
# Universe = DYNAMIC source ids (app/store/universes.py), fetched fresh each sweep so membership
# stays current: us_sp500 / us_all / kr_kospi200 / kr_kosdaq150 / kr_kospi_all / kr_kosdaq_all,
# and/or the legacy explicit form "US:AAPL,MSFT;KR:005930".
SCHEDULER_UNIVERSE=us_sp500,kr_kospi200,kr_kosdaq150
# CE-0: years of daily OHLCV the prices pipeline stores (deep enough for screener/quant/backtest).
PRICES_BACKFILL_YEARS=5
# The RAG service the news pipeline indexes into, + headlines fetched per ticker.
RAG_URL=http://rag:8002
NEWS_INGEST_LIMIT=8

# --- control plane ---------------------------------------------------------
ADMIN_TOKEN=dev-admin-token
RATE_LIMIT_PER_MINUTE=120

# --- studio-api + web (product layer) --------------------------------------
# Trust token between the web BFF and studio-api.
SERVICE_TOKEN=dev-service-token
# Agent planner: stub (deterministic, no key) | gemini (real LLM, needs GOOGLE_API_KEY)
AGENT_LLM_BACKEND=stub
# Gemini model id used when AGENT_LLM_BACKEND=gemini (any valid Gemini model).
AGENT_MODEL=gemini-flash-latest
# Light/cheap model for the first-pass intake: guardrail + step budget + plan + data routing.
AGENT_BUDGET_MODEL=gemini-flash-lite-latest
# Response/synthesis model — composes the user-facing final answer (+ A2A combiner + conceptual)
# that MIXES sourced facts (cited) with analyst context. This is what the user reads → DEEP tier
# (pro) for quality. Drop to a flash tier to cut cost/latency if needed.
AGENT_SYNTHESIS_MODEL=gemini-pro-latest
# Verify/refine + per-source confidence pass that grounds the synthesis. Flash by default;
# bump to a pro/reasoning model for stricter grounding.
AGENT_REASONING_MODEL=gemini-flash-latest
# Quality eval (eval/run_eval.py): the DEEP model that grades answers against the
# rubric (eval/RUBRIC.md), and the pass threshold for its overall score.
EVAL_JUDGE_MODEL=gemini-pro-latest   # e.g. gemini-3.5-pro-preview for the strongest grading
EVAL_JUDGE_BAR=3.8
# Required for the gemini backend (also used by RAG's gcp embedder). One key for all Gemini
# use. Get one at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=
# Then run the live LLM end-to-end test:  bash scripts/e2e_live.sh
#
# Web (Next.js / Auth.js). NOTE: docker compose env_file values are literal —
# keep comments on their OWN lines (an inline "# ..." can be parsed into the value,
# which would make AUTH_DEV_LOGIN != "true" and break login).
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me
# Log in with any email locally (no Google needed). Unset this for production.
AUTH_DEV_LOGIN=true
# For real Google OAuth instead, set these (and remove AUTH_DEV_LOGIN):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Feature flags — toggle whole product surfaces on/off (the web reads these server-side; restart to
# apply). Default ON when unset; set to false/0/off to hide. Keep on their OWN comment lines.
# FEATURE_DASHBOARD — the 대시보드 (Board) tab + pin-to-dashboard actions.
FEATURE_DASHBOARD=true
# FEATURE_ALERTS — the 알림봇 (notifications) tab + per-widget/board alert bells.
FEATURE_ALERTS=true
# DATASETS_URL is set by docker compose to http://datasets:8000; locally defaults
# to http://127.0.0.1:8000.

# --- RAG service (Gemini embeddings) ---------------------------------------
# Embeddings are Gemini-only: gemini-embedding-2 (latest) via the Gemini API using the SAME
# GOOGLE_API_KEY above — no service account / project needed. (Or gemini-embedding-001.)
RAG_EMBEDDING_MODEL=gemini-embedding-2
RAG_EMBEDDING_DIM=1536            # 768 | 1536 | 3072 (1536 = strong + pgvector-indexable)
# reranker: none (default) | gcp (Vertex Ranking API). For gcp: drop a service-account JSON at
# ./secrets/gcp-sa.json (compose mounts it + sets GOOGLE_APPLICATION_CREDENTIALS), enable the
# Discovery Engine API on the project, then set the next 3 lines.
RAG_RERANKER_BACKEND=none
# RAG_GCP_PROJECT=your-project-id
# RAG_GCP_LOCATION=global
# RAG_RERANKER_MODEL=semantic-ranker-default@latest
# vector store: pgvector (persistent, HNSW; Postgres in the `postgres` compose service) | memory (dev)
RAG_VECTOR_STORE=pgvector
# RAG_DATABASE_URL is injected by docker compose → postgresql://rag:rag@postgres:5432/rag

# --- notification alerts (F3 messengers) -----------------------------------
# The studio-api background worker fires due alerts and pushes sourced messages to the
# user's channels. Channel credentials are BYO and stored server-side per user (linked via
# POST /channels), never in the browser. With no credentials a delivery is recorded as
# "simulated" (the message we WOULD have sent) so the alert -> delivery flow works end-to-end
# without external accounts.
ALERTS_SCHEDULER_ENABLED=true
ALERTS_TICK_SECONDS=60
# Per-user channel config JSON shapes (sent to POST /channels, kept server-side):
# Telegram:  { "bot_token": "<@BotFather token>", "chat_id": "<chat id>" }
# Slack:     { "webhook_url": "https://hooks.slack.com/services/..." }
# Email:     { "webhook_url": "<transactional relay url>", "to": "you@example.com" }
# KakaoTalk: { "webhook_url": "<alimtalk/biz-message relay>" }  (else simulated)
# Optional platform fallbacks (used only if a user hasn't linked their own):
# TELEGRAM_BOT_TOKEN=
# SLACK_WEBHOOK_URL=
# KAKAO_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# --- infra: Postgres --------------------------------------------------------
# Runtime stores are Postgres — docker-compose points each service at its own DB on the `postgres`
# service (rag · datasets · controlplane · studio; the extra DBs are created by postgres-init/).
# DATABASE_URL here is unused (compose sets it per-service); override only for a non-compose run.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# REDIS_URL=redis://...

# --- admin panel (:8005) ---
ADMINUI_USERNAME=admin
ADMINUI_PASSWORD=admin
ADMINUI_SECRET=dev-adminui-secret-change-me
